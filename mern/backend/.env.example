# SQL Server connection settings
SQL_SERVER=localhost
SQL_PORT=1433
SQL_DATABASE=YourDatabaseName
# Use SQL Server Authentication with username/password
SQL_USER=YourSqlUsername
SQL_PASSWORD=YourSqlPassword

# Or use Windows authentication by setting this to true and leaving SQL_USER/SQL_PASSWORD empty
SQL_TRUSTED_CONNECTION=true

# App settings
PORT=5000
JWT_SECRET=your_jwt_secret_here
